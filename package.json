{
  "name": "openclaw-installer",
  "version": "1.0.0",
  "description": "小龙虾一键安装客户端，面向不会代码和命令行的 Windows/macOS 用户",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10",
  "repository": {
    "type": "git",
    "url": "https://github.com/gengyu/crayfish-installer.git"
  },
  "homepage": "https://github.com/gengyu/crayfish-installer",
  "bugs": {
    "url": "https://github.com/gengyu/crayfish-installer/issues"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win nsis --x64",
    "build:win:arm64": "tsc && vite build && electron-builder --win nsis --arm64",
    "build:mac": "tsc && vite build && electron-builder --mac dmg",
    "build:release": "tsc && vite build && electron-builder --publish always",
    "build:release:mac": "tsc && vite build && electron-builder --mac dmg --publish always",
    "build:release:win": "tsc && vite build && electron-builder --win nsis --x64 --publish always",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "execa": "^9.6.0",
    "json5": "^2.2.3",
    "semver": "^7.7.2",
    "shell-env": "^4.0.1",
    "sudo-prompt": "^9.2.1",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "1.6.1",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.crayfish.installer",
    "productName": "小龙虾安装器",
    "copyright": "Copyright © 2026 小龙虾安装器 contributors",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "gengyu",
        "repo": "crayfish-installer",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "OpenClawInstaller"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "小龙虾安装器",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
