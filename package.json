{
  "name": "openclaw-installer",
  "version": "1.0.0",
  "description": "小龙虾一键安装客户端，面向不会代码和命令行的 Windows/macOS 用户",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win nsis --x64",
    "build:win:arm64": "tsc && vite build && electron-builder --win nsis --arm64",
    "build:mac": "tsc && vite build && electron-builder --mac dmg",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron ."
  },
  "dependencies": {
    "execa": "^9.6.0",
    "electron-log": "^5.0.1",
    "shell-env": "^4.0.1",
    "semver": "^7.7.2",
    "sudo-prompt": "^9.2.1",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.5.8",

    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.crayfish.installer",
    "productName": "小龙虾安装器",
    "copyright": "Copyright © 2026 小龙虾安装器",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "OpenClawInstaller"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "小龙虾安装器",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
